<%- include("partials/head.ejs") %>
    <%- include("partials/header.ejs") %>

        <h2>
            <%= item ? "Edit Item" : "Add Item" %>
        </h2>

        <form method="POST" action="<%= item ? '/wishlist/update/' + item._id : '/wishlist' %>">
            <input type="hidden" name="_csrf" value="<%= _csrf %>" />

            <div>
                <label>Item:</label>
                <input name="name" value="<%= item ? item.name : '' %>" />
            </div>

            <div>
                <label>imageURL:</label>
                <input name="imageURL" value="<%= item ? item.imageURL : '' %>" />
            </div>

            <div>
                <label>link:</label>
                <input name="link" value="<%= item ? item.link : '' %>" />
            </div>

            <div>
                <label>description:</label>
                <input name="description" type="text" value="<%= item ? item.description : '' %>" />
            </div>

            <div>
                <label>priority (1 = most wanted, 5 = least important):</label>
                <select name="priority">
                    <option value="1" <%=item && item.priority==='1' ? 'selected' : '' %>>1</option>
                    <option value="2" <%=item && item.priority==='2' ? 'selected' : '' %>>2</option>
                    <option value="3" <%=item && item.priority==='3' ? 'selected' : '' %>>3</option>
                    <option value="4" <%=item && item.priority==='4' ? 'selected' : '' %>>4</option>
                    <option value="5" <%=item && item.priority==='5' ? 'selected' : '' %>>5</option>
                </select>
            </div>

            <button>
                <%= item ? "Update" : "Create" %>
            </button>
        </form>

        <%- include("partials/footer.ejs") %>