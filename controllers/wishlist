const Wishlist = require("../models/wishlist");
const parseVErr = require("../utils/parseValidationErrs");

const getAllItems = async (req, res) => {
  const items = await Wishlist.find({ createdBy: req.user._id });
  res.render("wishlistPrivate", { items });
};

const showNewForm = (req, res) => {
  res.render("Item", { item: null });
};

const createItem = async (req, res, next) => {
  try {
    await Wishlist.create({
      ...req.body,
      createdBy: req.user._id,
    });
    req.flash("info", "item created.");
    res.redirect("/wishlist");
  } catch (e) {
    if (e.name === "ValidationError") {
      parseVErr(e, req);
      return res.render("item", { item: null });
    }
    next(e);
  }
};

const showEditForm = async (req, res, next) => {
  const item = await Wishlist.findOne({
    _id: req.params.id,
    createdBy: req.user._id,
  });

  if (!item) {
    req.flash("error", "item not found.");
    return res.redirect("/items");
  }

  res.render("item", { item });
};

const updateItem = async (req, res, next) => {};

const deleteItem = async (req, res, next) => {};

const shareWishlist = async (req, res, next) => {
  const items = await Wishlist.find({ createdBy: req.params.id });
  res.render("wishlistShare", { items });
};

module.exports = {
  getAllItems,
  showNewForm,
  createItem,
  showEditForm,
  updateItem,
  deleteItem,
  shareWishlist,
};
